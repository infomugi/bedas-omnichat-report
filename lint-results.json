{\n          try {\n            cookieStore.set({ name, value: '', ...options })\n          } catch (error) {\n            // The `remove` method was called from a Server Component.\n            // This can be ignored if you have middleware refreshing\n            // user sessions.\n          }\n        },\n      },\n    }\n  )\n}\n","usedDeprecatedRules":[]}]
